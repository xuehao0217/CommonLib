# 项目根配置，所有编辑器（Android Studio / Cursor / VS Code）自动读取
root = true

# 全局默认
[*]
charset = utf-8                  # 文件编码统一 UTF-8，避免中文乱码
end_of_line = lf                 # 换行符统一 LF（Mac/Linux 标准），避免跨平台 diff 混乱
insert_final_newline = true      # 文件末尾自动加空行（Git 规范，避免 diff 多出 "No newline" 提示）
trim_trailing_whitespace = true  # 自动删除行尾多余空格

# Kotlin 源码和 Gradle Kotlin DSL
[*.{kt,kts}]
indent_style = space  # 按 Tab 键插入空格，不是 Tab 字符
indent_size = 4       # 缩进 4 个空格（Kotlin 官方风格）
max_line_length = 120 # 单行最长 120 字符，超了考虑换行

# XML（布局、资源、AndroidManifest）
[*.xml]
indent_style = space
indent_size = 4

# Gradle 版本目录
[*.toml]
indent_style = space
indent_size = 4

# Markdown 文档
[*.md]
trim_trailing_whitespace = false # Markdown 里行尾两个空格 = 强制换行，所以不能删

# ProGuard / R8 混淆规则
[*.pro]
indent_style = space
indent_size = 4
